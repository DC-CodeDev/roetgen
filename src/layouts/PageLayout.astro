---
import BaseLayout from './BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';

export interface BreadcrumbItem {
  label: string;
  href: string | null;
}

interface Props {
  title: string;
  description: string;
  breadcrumb?: BreadcrumbItem[];
}

const { title, description, breadcrumb = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header id="site-header">
    <div class="header-inner">
      <a href="/" class="site-title">PROYECTO ROENTGEN</a>
      <div class="header-actions">
        <button class="icon-btn" aria-label="Buscar" type="button" id="search-open-btn">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <circle cx="7.5" cy="7.5" r="5"></circle>
            <line x1="11.3" y1="11.3" x2="16" y2="16"></line>
          </svg>
        </button>
        <ThemeToggle client:load />
      </div>
    </div>
  </header>

  <!-- Search overlay -->
  <div id="search-overlay" class="search-overlay" hidden aria-modal="true" role="dialog" aria-label="Buscar">
    <div class="search-box">
      <div class="search-header">
        <svg width="16" height="16" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <circle cx="7.5" cy="7.5" r="5"></circle>
          <line x1="11.3" y1="11.3" x2="16" y2="16"></line>
        </svg>
        <input
          id="search-input"
          class="search-input"
          type="search"
          placeholder="Buscar proyecciones..."
          autocomplete="off"
          spellcheck="false"
        />
        <button id="search-close-btn" class="search-close" aria-label="Cerrar búsqueda">ESC</button>
      </div>
      <div id="search-results" class="search-results"></div>
    </div>
    <button class="search-backdrop" id="search-backdrop" aria-label="Cerrar"></button>
  </div>

  <main>
    {breadcrumb.length > 0 && (
      <nav class="breadcrumb" aria-label="Ubicación">
        {breadcrumb.map((item, i) => (
          <>
            {i > 0 && <span class="bc-sep">/</span>}
            {item.href
              ? <a href={item.href} class="bc-prev">{item.label}</a>
              : <span class="bc-current">{item.label}</span>
            }
          </>
        ))}
      </nav>
    )}
    <slot />
  </main>
</BaseLayout>

<script>
  // ── Search ──────────────────────────────────────────────────────
  const openBtn = document.getElementById('search-open-btn');
  const overlay = document.getElementById('search-overlay') as HTMLElement | null;
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const closeBtn = document.getElementById('search-close-btn');
  const backdrop = document.getElementById('search-backdrop');
  const resultsEl = document.getElementById('search-results');

  let pagefind: any = null;

  async function loadPagefind() {
    if (pagefind) return;
    try {
      pagefind = await import(/* @vite-ignore */ '/_pagefind/pagefind.js');
      await pagefind.init();
    } catch {
      // Not available in dev mode
    }
  }

  function openSearch() {
    if (!overlay || !input) return;
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    input.focus();
    loadPagefind();
  }

  function closeSearch() {
    if (!overlay || !input) return;
    overlay.hidden = true;
    document.body.style.overflow = '';
    input.value = '';
    if (resultsEl) resultsEl.innerHTML = '';
  }

  openBtn?.addEventListener('click', openSearch);
  closeBtn?.addEventListener('click', closeSearch);
  backdrop?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
  });

  input?.addEventListener('input', async () => {
    if (!resultsEl) return;
    const query = input.value.trim();
    if (!query || !pagefind) { resultsEl.innerHTML = ''; return; }

    const search = await pagefind.search(query);
    const items = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));

    if (!items.length) {
      resultsEl.innerHTML = '<p class="search-empty">Sin resultados</p>';
      return;
    }

    resultsEl.innerHTML = items.map((d: any) => `
      <a href="${d.url}" class="search-result">
        <span class="result-title">${d.meta?.title ?? ''}</span>
        <span class="result-excerpt">${d.excerpt}</span>
      </a>
    `).join('');
  });
</script>

<script>
  // Auto-hide header on mobile scroll
  const header = document.getElementById('site-header');
  if (header) {
    let lastY = window.scrollY;
    let ticking = false;

    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y > lastY && y > 60) {
          header.classList.add('header-hidden');
        } else {
          header.classList.remove('header-hidden');
        }
        lastY = y;
        ticking = false;
      });
    }, { passive: true });
  }
</script>

<style>
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(254, 247, 229, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: transform 250ms ease;
  }

  :global([data-theme="dark"]) #site-header {
    background: rgba(38, 41, 72, 0.9);
  }

  @media (max-width: 1023px) {
    #site-header.header-hidden {
      transform: translateY(-100%);
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
  }

  @media (min-width: 1024px) {
    .header-inner {
      padding: 18px 40px;
    }
  }

  .site-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 21px;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--text);
    text-decoration: none;
  }

  @media (min-width: 1024px) {
    .site-title {
      font-size: 26px;
    }
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .header-actions {
      gap: 20px;
    }
  }

  .icon-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--text);
    display: flex;
    align-items: center;
    line-height: 0;
  }

  main {
    /* offset for fixed header: 15+21+15+1 = 52px mobile, 18+26+18+1 = 63px desktop */
    padding-top: 52px;
  }

  @media (min-width: 1024px) {
    main {
      padding-top: 63px;
    }
  }

  /* ── Breadcrumb ──────────────────────────────────────────────── */

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: 14px 20px 0;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    line-height: 1;
  }

  @media (min-width: 1024px) {
    .breadcrumb {
      padding: 16px 40px 0;
    }
  }

  .bc-sep {
    color: var(--muted);
    margin: 0 5px;
  }

  .bc-prev {
    color: var(--muted);
    text-decoration: none;
  }

  .bc-prev:hover {
    color: var(--text);
  }

  .bc-current {
    color: var(--text);
  }

  /* ── Search overlay ──────────────────────────────────────────── */

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }

  .search-overlay[hidden] {
    display: none;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    cursor: default;
    backdrop-filter: blur(4px);
  }

  .search-box {
    position: relative;
    z-index: 1;
    width: min(600px, calc(100vw - 32px));
    background: var(--bg);
    border: 1px solid var(--border);
    max-height: calc(100vh - 120px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
  }

  .search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    color: var(--text);
  }

  .search-input::placeholder {
    color: var(--muted);
  }

  .search-close {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'Outfit', sans-serif;
    font-size: 11px;
    padding: 3px 6px;
    cursor: pointer;
    flex-shrink: 0;
  }

  .search-results {
    overflow-y: auto;
    padding: 8px 0;
  }

  .search-result {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    transition: background 150ms ease;
  }

  .search-result:last-child {
    border-bottom: none;
  }

  .search-result:hover {
    background: var(--surface);
  }

  .result-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.03em;
    line-height: 1;
  }

  .result-excerpt {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  :global(.search-result mark) {
    background: var(--accent-bg);
    color: var(--accent-text);
    padding: 0 2px;
  }

  .search-empty {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    color: var(--muted);
    padding: 20px 16px;
    text-align: center;
  }
</style>
