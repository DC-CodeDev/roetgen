---
import BaseLayout from './BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';

export interface BreadcrumbItem {
  label: string;
  href: string | null;
}

interface Props {
  title: string;
  description: string;
  breadcrumb?: BreadcrumbItem[];
}

const { title, description, breadcrumb = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header id="site-header">
    <div class="header-inner">
      <a href="/" class="site-title">PROYECTO ROENTGEN</a>
      <div class="header-actions">
        <button class="icon-btn" aria-label="Buscar" type="button">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <circle cx="7.5" cy="7.5" r="5"></circle>
            <line x1="11.3" y1="11.3" x2="16" y2="16"></line>
          </svg>
        </button>
        <ThemeToggle client:load />
      </div>
    </div>
  </header>

  <main>
    {breadcrumb.length > 0 && (
      <nav class="breadcrumb" aria-label="Ubicación">
        {breadcrumb.map((item, i) => (
          <>
            {i > 0 && <span class="bc-sep">/</span>}
            {item.href
              ? <a href={item.href} class="bc-prev">{item.label}</a>
              : <span class="bc-current">{item.label}</span>
            }
          </>
        ))}
      </nav>
    )}
    <slot />
  </main>
</BaseLayout>

<script>
  // Auto-hide header on mobile scroll
  const header = document.getElementById('site-header');
  if (header) {
    let lastY = window.scrollY;
    let ticking = false;

    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y > lastY && y > 60) {
          header.classList.add('header-hidden');
        } else {
          header.classList.remove('header-hidden');
        }
        lastY = y;
        ticking = false;
      });
    }, { passive: true });
  }
</script>

<style>
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(254, 247, 229, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: transform 250ms ease;
  }

  :global([data-theme="dark"]) #site-header {
    background: rgba(38, 41, 72, 0.9);
  }

  @media (max-width: 1023px) {
    #site-header.header-hidden {
      transform: translateY(-100%);
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
  }

  @media (min-width: 1024px) {
    .header-inner {
      padding: 18px 40px;
    }
  }

  .site-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 21px;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--text);
    text-decoration: none;
  }

  @media (min-width: 1024px) {
    .site-title {
      font-size: 26px;
    }
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .header-actions {
      gap: 20px;
    }
  }

  .icon-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--text);
    display: flex;
    align-items: center;
    line-height: 0;
  }

  main {
    /* offset for fixed header: 15+21+15+1 = 52px mobile, 18+26+18+1 = 63px desktop */
    padding-top: 52px;
  }

  @media (min-width: 1024px) {
    main {
      padding-top: 63px;
    }
  }

  /* ── Breadcrumb ──────────────────────────────────────────────── */

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: 14px 20px 0;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    line-height: 1;
  }

  @media (min-width: 1024px) {
    .breadcrumb {
      padding: 16px 40px 0;
    }
  }

  .bc-sep {
    color: var(--muted);
    margin: 0 5px;
  }

  .bc-prev {
    color: var(--muted);
    text-decoration: none;
  }

  .bc-prev:hover {
    color: var(--text);
  }

  .bc-current {
    color: var(--text);
  }
</style>
