---
import BaseLayout from './BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.tsx';
import Search from '../components/Search.tsx';

export interface BreadcrumbItem {
  label: string;
  href: string | null;
}

interface Props {
  title: string;
  description: string;
  breadcrumb?: BreadcrumbItem[];
}

const { title, description, breadcrumb = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header id="site-header">
    <div class="header-inner">
      <a href="/" class="site-title">PROYECTO ROENTGEN</a>
      <div class="header-actions">
        <Search client:load />
        <ThemeToggle client:load />
      </div>
    </div>
  </header>

  <main>
    {breadcrumb.length > 0 && (
      <nav class="breadcrumb" aria-label="Ubicación">
        {breadcrumb.map((item, i) => (
          <>
            {i > 0 && <span class="bc-sep">/</span>}
            {item.href
              ? <a href={item.href} class="bc-prev">{item.label}</a>
              : <span class="bc-current">{item.label}</span>
            }
          </>
        ))}
      </nav>
    )}
    <slot />
  </main>
</BaseLayout>

<script>
  // Auto-hide header on mobile scroll
  const header = document.getElementById('site-header');
  if (header) {
    let lastY = window.scrollY;
    let ticking = false;

    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y > lastY && y > 60) {
          header.classList.add('header-hidden');
        } else {
          header.classList.remove('header-hidden');
        }
        lastY = y;
        ticking = false;
      });
    }, { passive: true });
  }
</script>

<style>
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(254, 247, 229, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: transform 250ms ease;
  }

  :global([data-theme="dark"]) #site-header {
    background: rgba(38, 41, 72, 0.9);
  }

  @media (max-width: 1023px) {
    #site-header.header-hidden {
      transform: translateY(-100%);
    }
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
  }

  @media (min-width: 1024px) {
    .header-inner {
      padding: 18px 40px;
    }
  }

  .site-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 21px;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--text);
    text-decoration: none;
  }

  @media (min-width: 1024px) {
    .site-title {
      font-size: 26px;
    }
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .header-actions {
      gap: 20px;
    }
  }

  main {
    /* offset for fixed header: 15+21+15+1 = 52px mobile, 18+26+18+1 = 63px desktop */
    padding-top: 52px;
  }

  @media (min-width: 1024px) {
    main {
      padding-top: 63px;
    }
  }

  /* ── Breadcrumb ──────────────────────────────────────────────── */

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: 14px 20px 0;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    line-height: 1;
  }

  @media (min-width: 1024px) {
    .breadcrumb {
      padding: 16px 40px 0;
    }
  }

  .bc-sep {
    color: var(--muted);
    margin: 0 5px;
  }

  .bc-prev {
    color: var(--muted);
    text-decoration: none;
  }

  .bc-prev:hover {
    color: var(--text);
  }

  .bc-current {
    color: var(--text);
  }

  /* ── Search (React component — todo global) ──────────────────── */

  :global(.search-trigger-btn) {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--text);
    display: flex;
    align-items: center;
    line-height: 0;
  }

  :global(.search-overlay) {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }

  :global(.search-backdrop) {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    cursor: default;
    backdrop-filter: blur(4px);
  }

  :global(.search-box) {
    position: relative;
    z-index: 1;
    width: min(600px, calc(100vw - 32px));
    background: var(--bg);
    border: 1px solid var(--border);
    max-height: calc(100vh - 120px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  :global(.search-header) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
    flex-shrink: 0;
  }

  :global(.search-input) {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    color: var(--text);
  }

  :global(.search-input::placeholder) {
    color: var(--muted);
  }

  :global(.search-close-btn) {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'Outfit', sans-serif;
    font-size: 11px;
    padding: 3px 6px;
    cursor: pointer;
    flex-shrink: 0;
  }

  :global(.search-results-list) {
    overflow-y: auto;
    padding: 4px 0;
  }

  :global(.search-result) {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 12px 16px;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    transition: background 150ms ease;
  }

  :global(.search-result:last-child) {
    border-bottom: none;
  }

  :global(.search-result:hover) {
    background: var(--surface);
  }

  :global(.result-title) {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.03em;
    line-height: 1;
  }

  :global(.result-meta) {
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.4;
  }

  :global(.search-empty) {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    color: var(--muted);
    padding: 20px 16px;
    text-align: center;
    margin: 0;
  }
</style>
