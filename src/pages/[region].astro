---
import { readdir } from 'node:fs/promises';
import { join } from 'node:path';
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import { REGION_SLUGS, getRegionName, getSubregionName, SUBREGION_ORDER } from '../lib/regions';

export async function getStaticPaths() {
  const enfoqueBase = join(process.cwd(), 'src/content/enfoques');
  const allEnfoques = await getCollection('enfoques');

  const paths = await Promise.all(
    REGION_SLUGS.map(async (region) => {
      let subregionSlugs: string[] = [];
      try {
        const entries = await readdir(join(enfoqueBase, region), { withFileTypes: true });
        subregionSlugs = entries.filter(e => e.isDirectory()).map(e => e.name);
      } catch {
        // folder may not exist yet
      }

      const regionEnfoques = allEnfoques.filter(e => e.data.region === region);

      // Región plana: una sola subcarpeta → mostrar enfoques directamente
      if (subregionSlugs.length === 1) {
        const sub = subregionSlugs[0];
        const enfoques = regionEnfoques
          .filter(e => e.data.subregion === sub)
          .sort((a, b) => (a.data.orden ?? 999) - (b.data.orden ?? 999))
          .map(e => ({
            titulo: e.data.titulo,
            href: `/${region}/${sub}/${e.id.split('/').at(-1)}`,
          }));
        return {
          params: { region },
          props: { regionNombre: getRegionName(region), subregiones: [], enfoques },
        };
      }

      const order = SUBREGION_ORDER[region];
      const sorted = order
        ? subregionSlugs.sort((a, b) => {
            const ia = order.indexOf(a);
            const ib = order.indexOf(b);
            return (ia === -1 ? 999 : ia) - (ib === -1 ? 999 : ib);
          })
        : subregionSlugs;

      const subregiones = sorted.map(sub => ({
        slug: sub,
        nombre: getSubregionName(sub),
        count: regionEnfoques.filter(e => e.data.subregion === sub).length,
        href: `/${region}/${sub}`,
      }));

      return {
        params: { region },
        props: {
          regionNombre: getRegionName(region),
          subregiones,
          enfoques: [],
        },
      };
    })
  );

  return paths;
}

const { region } = Astro.params;
const { regionNombre, subregiones, enfoques } = Astro.props;

const breadcrumb = [
  { label: 'Inicio', href: '/' },
  { label: regionNombre, href: null },
];
---

<PageLayout
  title={`${regionNombre} | Proyecto Roentgen`}
  description={`Proyecciones radiológicas de ${regionNombre.toLowerCase()}.`}
  breadcrumb={breadcrumb}
>
  <div class="page-content">
    <h1 class="page-title">{regionNombre.toUpperCase()}</h1>
    <div class="divider"></div>
    {enfoques.length > 0 ? (
      <div class="enfoque-list">
        {enfoques.map((enf, i) => (
          <a href={enf.href} class="rg-card rg-card--flat" aria-label={enf.titulo} style={`--i: ${i}`}>
            <span class="card-name">{enf.titulo.toUpperCase()}</span>
          </a>
        ))}
      </div>
    ) : (
      <div class="subregion-grid">
        {subregiones.map((sub, i) => (
          <a href={sub.href} class="rg-card" aria-label={sub.nombre} style={`--i: ${i}`}>
            <span class="card-name">{sub.nombre.toUpperCase()}</span>
            <span class="card-count">{sub.count} {sub.count === 1 ? 'enfoque' : 'enfoques'}</span>
          </a>
        ))}
        {subregiones.length === 0 && (
          <p class="empty-note">Sin subregiones disponibles</p>
        )}
      </div>
    )}
  </div>
</PageLayout>

<style>
  .page-content {
    padding: 18px 20px 40px;
  }

  @media (min-width: 1024px) {
    .page-content {
      padding: 26px 40px 56px;
    }
  }

  .page-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 46px;
    letter-spacing: 0.02em;
    line-height: 0.92;
    margin-bottom: 0;
  }

  @media (min-width: 640px) {
    .page-title {
      font-size: 56px;
    }
  }

  @media (min-width: 1024px) {
    .page-title {
      font-size: 64px;
    }
  }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 14px 0 18px;
  }

  /* ── Grid ──────────────────────────────────────────────────── */

  .subregion-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (min-width: 1024px) {
    .subregion-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
  }

  /* ── Card ──────────────────────────────────────────────────── */

  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .rg-card {
    min-height: 96px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
    opacity: 0;
    animation: cardFadeIn 150ms ease-out forwards;
    animation-delay: calc(var(--i) * 150ms);
  }

  @media (hover: hover) {
    .rg-card:hover {
      background: var(--accent-bg);
      color: var(--accent-text);
      border-color: var(--accent-bg);
    }
  }

  @media (hover: none) {
    .rg-card:active {
      background: var(--accent-bg);
      color: var(--accent-text);
      border-color: var(--accent-bg);
    }
  }

  /* ── Card content ─────────────────────────────────────────── */

  .card-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 0.03em;
    line-height: 1;
  }

  .card-count {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    color: var(--muted);
    margin-top: 5px;
  }

  /* When card is hovered, count inherits the inverted color via currentColor
     but we want it to fade — use opacity on the count text */
  .rg-card:hover .card-count,
  .rg-card:active .card-count {
    color: inherit;
    opacity: 0.7;
  }

  .empty-note {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    color: var(--muted);
    grid-column: 1 / -1;
    padding: 20px 0;
  }

  /* ── Modo plano (región sin subregiones) ──────────────────── */

  .enfoque-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rg-card--flat {
    min-height: 72px;
    justify-content: center;
    padding: 16px 20px;
  }

  .rg-card--flat .card-name {
    font-size: 28px;
    letter-spacing: 0.04em;
  }
</style>
